# ==============================================================
# .env.example — Plantilla de credenciales para Gastos Personal
# ==============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena tus valores reales de Supabase
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# Encuéntralos en:
#   Supabase Dashboard → Tu Proyecto → Settings → API
# ==============================================================

SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA
